        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "sun = np.array([0.0,0.0])\n",
        "r = np.array([1.0, 0.0])\n",
        "v = np.array([0.0,10.0])\n",
        "dt = 0.001\n",
        "GM = 4*np.pi**2\n",
        "\n",
        "def acceleration(r):\n",
        "    d = np.linalg.norm(r)\n",
        "    return - GM*r / d**3\n",
        "trajectory = []\n",
        "for _ in range(9000):\n",
        "  a = acceleration(r)\n",
        "  v = v + a*dt\n",
        "  r = r + v*dt\n",
        "  trajectory.append(r.copy())\n",
        "trajectory = np.array(trajectory)\n",
        "plt.plot (trajectory[:,0], trajectory[:,1])\n",
        "plt.scatter (0,0, color = \"orange\")\n",
        "plt.title (\"Planet going outwards for high sideways velocity\")\n",
        "plt.axis (\"Equal\")\n",
        "plt.show()"
      ]
    }
